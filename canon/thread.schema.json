 {
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Domain-8 Threads Array",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "immutable_id",
      "display_number",
      "title",
      "creation_timestamp",
      "share_link",
      "status"
    ],
    "properties": {
      "immutable_id": {
        "type": "string",
        "pattern": "^T-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$|^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
        "minLength": 12,
        "readOnly": true
      },
      "display_number": { "type": "string" },
      "title": { "type": "string", "minLength": 1 },
      "creation_timestamp": { "type": "string", "format": "date-time" },
      "share_link": { "type": "string", "format": "uri" },
      "status": { "type": "string", "enum": ["DRAFT", "LIVE", "SUPERSEDED", "FOSSIL"] },
      "supersedes": { "type": ["string", "null"] },
      "superseded_by": { "type": ["string", "null"] },
      "tags": { "type": "array", "items": { "type": "string" } },
      "epoch": { "type": ["string", "null"] },
      "last_modified": { "type": ["string", "null"], "format": "date-time" }
    },
    "additionalProperties": false
  }
}